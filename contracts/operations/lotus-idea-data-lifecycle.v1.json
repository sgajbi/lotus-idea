      "field_classification_profile_ref": "operational_delivery:v1",
      "residency_policy_ref": "bank-approved-primary-and-dr-regions:v1",
      "data_classes": ["confidential_operational_metadata"],
      "purpose": "duplicate_mutation_prevention",
      "policy_ref": "lotus-idea:operational-delivery:four-hundred-day:v1",
      "hold_behavior": "freeze_expiry_and_purge",
      "erasure_policy": "preserve_hash_only_replay_fence",
      "purge_policy": "purge_after_expiry_when_candidate_tombstone_blocks_recreation"
