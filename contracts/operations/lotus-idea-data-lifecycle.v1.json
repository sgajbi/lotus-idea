      "policy_ref": "lotus-idea:regulated-advisory-evidence:seven-year:v1",
      "hold_behavior": "freeze_expiry_erasure_and_purge",
      "erasure_policy": "pseudonymize_actor_preserve_transition_tombstone",
      "purge_policy": "immutable_tombstone_only"
