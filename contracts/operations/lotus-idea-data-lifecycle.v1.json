{
  "contract_id": "lotus-idea-data-lifecycle",
  "contract_version": "1.1.0",
  "repository": "lotus-idea",
  "data_owner": "lotus-idea",
  "certification_status": "not_certified",
  "supported_feature_promoted": false,
  "source_of_truth": {
    "migrations": "migrations",
    "persistence": "docs/operations/persistence.md",
    "slice": "docs/rfcs/RFC-0002-enterprise-opportunity-intelligence-operating-layer/RFC-0002-slice-06-persistence-replay-idempotency-and-audit.md"
  },
  "authority_boundaries": {
    "local_enforcement_owner": "lotus-idea",
    "retention_policy_approval_authority": "bank-records-and-privacy-governance",
    "legal_hold_decision_authority": "bank-legal-and-records-governance",
    "subject_erasure_decision_authority": "bank-privacy-governance",
    "report_policy_source_authority": "lotus-report",
    "archive_record_source_authority": "lotus-archive",
    "ai_provider_retention_source_authority": "lotus-ai",
    "idea_may_self_authorize_legal_hold_or_erasure": false
  },
  "residency_policies": {
    "bank-approved-primary-and-dr-regions:v1": {
      "storage_boundary": "deployment-configured bank-approved primary and disaster-recovery regions",
      "cross_region_replication": "bank-approved encrypted replication only",
      "cross_border_transfer_authority": "bank-privacy-and-outsourcing-governance"
    }
  },
  "field_classification_profiles": {
    "regulated_payload:v1": {
      "rules": {
        "*_json": "restricted_advisory_evidence",
        "*_id|*_ref|candidate_id|tenant_id": "restricted_client_data",
        "actor_subject|approver_subject": "restricted_audit_identity",
        "*_hash|*_fingerprint": "confidential_operational_metadata",
        "*_at_utc|version|status|state": "confidential_operational_metadata"
      },
      "fallback_class": "restricted_advisory_evidence"
    },
    "regulated_audit:v1": {
      "rules": {
        "actor_subject|approver_subject": "restricted_audit_identity",
        "*_json|reason|change_reference|authority_ref": "restricted_security_audit",
        "*_id|candidate_id|tenant_id": "restricted_privacy_control",
        "*_at_utc|version|status|state": "confidential_operational_metadata"
      },
      "fallback_class": "restricted_security_audit"
    },
    "operational_delivery:v1": {
      "rules": {
        "payload_json|audit_json|failure_reason": "restricted_advisory_evidence",
        "*_id|*_key|*_reference": "confidential_operational_metadata",
        "actor_subject|lease_owner": "restricted_audit_identity",
        "*_at_utc|status|target|attempt_count": "confidential_operational_metadata"
      },
      "fallback_class": "confidential_operational_metadata"
    },
    "privacy_control:v1": {
      "rules": {
        "tenant_id|candidate_id|actor_subject|approver_subject": "restricted_privacy_control",
        "authority_ref|change_reference|reason|*_json": "restricted_security_audit",
        "*_hash|*_fingerprint|policy_ref": "confidential_operational_metadata",
        "*_at_utc|version|state|action|decision": "confidential_operational_metadata"
      },
      "fallback_class": "restricted_privacy_control"
    },
    "quarantine:v1": {
      "rules": {
        "*_json": "restricted_advisory_evidence",
        "candidate_id|conversion_intent_id": "restricted_client_data",
        "quarantine_reason|original_status": "confidential_operational_metadata",
        "*_at_utc": "confidential_operational_metadata"
      },
      "fallback_class": "restricted_advisory_evidence"
    }
  },
  "retention_policies": [
    {
      "policy_ref": "lotus-idea:regulated-advisory-evidence:seven-year:v1",
      "duration": "P7Y",
      "start_event": "candidate_terminal_or_last_regulated_event",
      "expiry_behavior": "operator_review_then_redact",
      "automatic_physical_delete": false
    },
    {
      "policy_ref": "lotus-idea:operational-delivery:four-hundred-day:v1",
      "duration": "P400D",
      "start_event": "terminal_delivery_or_last_recovery_event",
      "expiry_behavior": "operator_review_then_purge",
      "automatic_physical_delete": false
    },
    {
      "policy_ref": "lotus-idea:quarantine:ninety-day:v1",
      "duration": "P90D",
      "start_event": "approved_reconciliation_or_erasure",
      "expiry_behavior": "operator_review_then_purge",
      "automatic_physical_delete": false
    }
  ],
  "accepted_external_policy_refs": {
    "lotus-report:idea-evidence-retention:v1": "lotus-idea:regulated-advisory-evidence:seven-year:v1"
  },
  "record_inventory": [
