      "field_classification_profile_ref": "regulated_payload:v1",
      "residency_policy_ref": "bank-approved-primary-and-dr-regions:v1",
      "data_classes": ["restricted_client_data", "restricted_advisory_evidence"],
      "purpose": "opportunity_candidate_and_deterministic_evidence",
      "policy_ref": "lotus-idea:regulated-advisory-evidence:seven-year:v1",
      "hold_behavior": "freeze_expiry_erasure_and_purge",
      "erasure_policy": "redact_payload_preserve_candidate_tombstone",
      "purge_policy": "immutable_tombstone_only"
    },
    {
