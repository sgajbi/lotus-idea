    "operation_metric_contract": "contracts/observability/lotus-idea-operation-metrics.v1.json",
    "contract_gate": "scripts/ai_model_risk_operations_contract_gate.py",
    "proof_contract_gate": "scripts/ai_model_risk_operations_proof_contract_gate.py",
    "dashboard": "monitoring/grafana/dashboards/lotus-idea-ai-model-risk-operations.json",
    "alert_rules": "monitoring/prometheus/rules/lotus-idea-ai-model-risk-operations.rules.yml",
    "model_risk_runbook": "docs/runbooks/ai-model-risk-operations.md",
    "operations_doc": "docs/operations/observability.md",
    "ai_governance_doc": "docs/operations/ai-governance.md",
    "operations_runbook": "wiki/Operations-Runbook.md",
    "rfc_slice_09": "docs/rfcs/RFC-0002-enterprise-opportunity-intelligence-operating-layer/RFC-0002-slice-09-governed-ai-explanation-and-model-risk-controls.md",
    "rfc_slice_15": "docs/rfcs/RFC-0002-enterprise-opportunity-intelligence-operating-layer/RFC-0002-slice-15-observability-security-entitlements-and-operations.md"
  },
  "model_risk_dashboard_controls": [
    {
      "control_id": "ai-explanation-readiness-posture",
      "operator_question": "Can operators see whether the AI explanation foundation is blocked, not certified, and unpromoted before any runtime or Workbench claim is made?",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "ai_explanation_readiness_read"
      ],
      "required_labels": [
        "operation",
        "outcome",
        "supportability_status",
        "source_authority",
        "durable_storage_backed",
        "supported_feature_promoted"
      ],
      "required_endpoint": "GET /api/v1/ai-explanations/readiness",
      "certification_status": "certified"
    },
    {
      "control_id": "ai-output-verifier-posture",
      "operator_question": "Can operators distinguish accepted, fallback, blocked, invalid-state, and permission-denied AI explanation outcomes without raw prompts or provider payloads?",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "ai_explanation"
      ],
      "required_labels": [
        "operation",
        "outcome",
        "supportability_status",
        "source_authority",
        "durable_storage_backed",
        "supported_feature_promoted"
      ],
      "required_endpoint": "POST /api/v1/idea-candidates/{candidateId}/ai-explanations/evaluate",
      "certification_status": "certified"
    },
    {
      "control_id": "ai-lineage-durability-posture",
      "operator_question": "Can operators see whether AI explanation lineage is backed by the active durable repository before treating the surface as certified?",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "ai_explanation",
        "ai_explanation_readiness_read"
      ],
      "required_labels": [
        "durable_storage_backed",
        "supported_feature_promoted"
      ],
      "required_endpoint": "GET /api/v1/ai-explanations/readiness",
      "certification_status": "certified"
    }
  ],
  "model_risk_alert_candidates": [
    {
      "alert_id": "ai-explanation-unsupported-claim-block-rate",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "ai_explanation"
      ],
      "required_outcomes": [
        "blocked"
      ],
      "operator_response": "Investigate whether workflow-pack output is citing unsupported source products or proposing prohibited actions. Do not inspect prompts or provider payloads in this service.",
      "certification_status": "certified"
    },
    {
      "alert_id": "ai-explanation-readiness-remains-blocked",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "ai_explanation_readiness_read"
      ],
      "required_outcomes": [
        "blocked"
      ],
      "operator_response": "Use the readiness endpoint to inspect lotus-ai runtime, lineage-store, workflow-pack, trust-telemetry, and Workbench blockers before any support promotion.",
      "certification_status": "certified"
    }
  ],
  "non_proof_boundaries": [
    "This contract is not lotus-ai runtime execution proof.",
    "This contract is not certified AI lineage-store proof.",
    "This contract is not Gateway or Workbench proof.",
    "This contract is not supported-feature promotion."
  ]
}
