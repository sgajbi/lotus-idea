{
  "contract_id": "lotus-idea-ai-model-risk-operations",
  "contract_version": "1.1.0",
  "repository": "lotus-idea",
  "lifecycle_status": "implemented_internal_foundation",
  "supportability_status": "not_certified",
  "supported_feature_promoted": false,
  "dashboard_certified": true,
  "alert_certified": true,
  "action_content_policy_version": "lotus-idea.ai-action-content-policy.v1",
  "output_integrity_version": "lotus-idea.ai-output-integrity.v1",
  "execution_provenance_policy_version": "lotus-idea.ai-execution-provenance-policy.v1",
  "metadata_envelope_version": "lotus-idea.ai-metadata-envelope.v1",
  "source_of_truth": {
    "ai_readiness_source": "src/app/application/ai_governance.py",
    "ai_api_source": "src/app/api/ai_governance.py",
    "action_policy_source": "src/app/domain/ai_action_policy.py",
    "output_integrity_source": "src/app/domain/ai_output_integrity.py",
    "execution_provenance_source": "src/app/domain/ai_execution_provenance.py",
    "metadata_policy_source": "src/app/domain/ai_metadata_policy.py",
    "data_lifecycle_contract": "contracts/operations/lotus-idea-data-lifecycle.v1.json",
    "operation_metric_contract": "contracts/observability/lotus-idea-operation-metrics.v1.json",
    "contract_gate": "scripts/ai_model_risk_operations_contract_gate.py",
    "proof_contract_gate": "scripts/ai_model_risk_operations_proof_contract_gate.py",
    "dashboard": "monitoring/grafana/dashboards/lotus-idea-ai-model-risk-operations.json",
    "alert_rules": "monitoring/prometheus/rules/lotus-idea-ai-model-risk-operations.rules.yml",
    "model_risk_runbook": "docs/runbooks/ai-model-risk-operations.md",
    "operations_doc": "docs/operations/observability.md",
    "ai_governance_doc": "docs/operations/ai-governance.md",
    "operations_runbook": "wiki/Operations-Runbook.md",
    "rfc_slice_09": "docs/rfcs/RFC-0002-enterprise-opportunity-intelligence-operating-layer/RFC-0002-slice-09-governed-ai-explanation-and-model-risk-controls.md",
    "rfc_slice_15": "docs/rfcs/RFC-0002-enterprise-opportunity-intelligence-operating-layer/RFC-0002-slice-15-observability-security-entitlements-and-operations.md"
  },
  "action_content_policy": {
    "input_posture": "untrusted_provider_content",
    "accepted_label_posture": "canonical_server_owned",
    "unsupported_script_posture": "fail_closed_ambiguous",
    "blocked_reasons": [
      "ambiguous_action_content",
      "forbidden_action_content",
      "forbidden_action_type"
    ],
    "raw_rejected_label_persisted": false,
    "raw_rejected_label_returned": false
  },
  "output_content_integrity": {
    "algorithm": "sha256",
    "canonicalization": "unicode_nfc_line_endings_order_preserving",
    "content_scope": [
      "explanation_text",
      "ordered_claim_id_text_and_source_bindings",
      "ordered_action_type_and_submitted_label",
      "workflow_pack_evaluator_and_policy_metadata"
    ],
    "persisted_content": "digest_and_version_only",
    "retention_policy_ref": "lotus-idea:regulated-advisory-evidence:seven-year:v1",
    "access_posture": "governed_evaluation_replay_or_authorized_lineage_store",
    "pre_v1_migration_posture": "explicitly_unverifiable_no_retroactive_claim"
  },
  "execution_provenance": {
    "production_like_policy": "verified_lotus_ai_attestation_required",
    "local_test_policy": "unattested_fixture_allowed_non_production_only",
    "fallback_policy": "deterministic_fallback_allowed_without_ai_execution",
    "producer_attestation_available": false,
    "producer_blocker": "sgajbi/lotus-ai#113",
    "unattested_output_clears_runtime_proof": false,
    "pre_attestation_migration_posture": "explicitly_unverifiable"
  },
  "provider_safe_metadata": {
    "classification": "non_sensitive_operational_routing",
    "maximum_fields": 2,
    "maximum_key_length": 32,
    "maximum_value_length": 64,
    "allowed_fields": {
      "channel": {
        "allowed_values": ["advisor-workbench"],
        "allowed_purposes": [
          "advisor_rationale_draft",
          "meeting_preparation_draft",
          "missing_evidence_check",
          "unsupported_claim_verification"
        ]
      },
      "audience": {
        "allowed_values": ["internal_advisor_review"],
        "allowed_purposes": [
          "advisor_rationale_draft",
          "meeting_preparation_draft"
        ]
      }
    },
    "unknown_field_posture": "reject_before_candidate_lookup_or_provider_call",
    "unapproved_value_posture": "reject_before_candidate_lookup_or_provider_call",
    "provider_forwarding": "approved_envelope_only",
    "raw_values_persisted": false,
    "raw_values_logged": false,
    "retained_projection": "sorted_approved_field_names_only"
  },
  "model_risk_dashboard_controls": [
    {
      "control_id": "ai-explanation-readiness-posture",
      "operator_question": "Can operators see whether the AI explanation foundation is blocked, not certified, and unpromoted before any runtime or Workbench claim is made?",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "ai_explanation_readiness_read"
      ],
      "required_labels": [
        "operation",
        "outcome",
        "supportability_status",
        "source_authority",
        "durable_storage_backed",
        "supported_feature_promoted"
      ],
      "required_endpoint": "GET /api/v1/ai-explanations/readiness",
      "certification_status": "certified"
    },
    {
      "control_id": "ai-output-verifier-posture",
      "operator_question": "Can operators distinguish accepted, fallback, blocked, invalid-state, and permission-denied AI explanation outcomes without raw prompts or provider payloads?",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "ai_explanation"
      ],
      "required_labels": [
        "operation",
        "outcome",
        "supportability_status",
        "source_authority",
        "durable_storage_backed",
        "supported_feature_promoted"
      ],
      "required_endpoint": "POST /api/v1/idea-candidates/{candidateId}/ai-explanations/evaluate",
      "certification_status": "certified"
    },
    {
      "control_id": "ai-lineage-durability-posture",
      "operator_question": "Can operators see whether AI explanation lineage is backed by the active durable repository before treating the surface as certified?",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "ai_explanation",
        "ai_explanation_readiness_read"
      ],
      "required_labels": [
        "durable_storage_backed",
        "supported_feature_promoted"
      ],
      "required_endpoint": "GET /api/v1/ai-explanations/readiness",
      "certification_status": "certified"
    }
  ],
  "model_risk_alert_candidates": [
    {
      "alert_id": "ai-explanation-unsupported-claim-block-rate",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "ai_explanation"
      ],
      "required_outcomes": [
        "blocked"
      ],
      "operator_response": "Investigate whether workflow-pack output is citing unsupported source products or proposing prohibited actions. Do not inspect prompts or provider payloads in this service.",
      "certification_status": "certified"
    },
    {
      "alert_id": "ai-explanation-readiness-remains-blocked",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "ai_explanation_readiness_read"
      ],
      "required_outcomes": [
        "blocked"
      ],
      "operator_response": "Use the readiness endpoint to inspect lotus-ai runtime, lineage-store, workflow-pack, trust-telemetry, and Workbench blockers before any support promotion.",
      "certification_status": "certified"
    }
  ],
  "non_proof_boundaries": [
    "This contract is not lotus-ai runtime execution proof.",
    "This contract is not certified AI lineage-store proof.",
    "This contract is not Gateway or Workbench proof.",
    "This contract is not supported-feature promotion."
  ]
}
