    "governed_labels": [
      "lotus-advise",
      "lotus-ai",
      "lotus-archive",
      "lotus-core",
      "lotus-idea",
      "lotus-manage",
      "lotus-performance",
      "lotus-render",
      "lotus-report",
      "lotus-risk",
      "source-owned"
    ],
    "operator_policy": "Dashboards and alerts may group by source_authority, but any explicit source_authority match must use only governed labels and must never encode client, portfolio, account, holding, request, response, or entitlement payload identity."
  },
  "operator_dashboard_controls": [
    {
      "control_id": "source-ingestion-readiness-and-run-once-posture",
      "operator_question": "Can operators see source-ingestion readiness and run-once blockage without source payloads or portfolio identifiers?",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "source_ingestion_readiness_read",
        "source_ingestion_run_once"
      ],
      "required_labels": [
        "operation",
        "outcome",
        "supportability_status",
        "source_authority",
        "durable_storage_backed",
        "supported_feature_promoted"
      ],
      "required_endpoints": [
        "GET /api/v1/source-ingestion/readiness",
        "POST /api/v1/source-ingestion/run-once"
      ],
      "certification_status": "certified"
    },
    {
      "control_id": "outbox-delivery-backlog-and-recovery-posture",
      "operator_question": "Can operators see outbox readiness and run-once failure pressure before dead-letter or recovery work is handled manually?",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "supportability_metric_families": [
        "lotus_idea_outbox_delivery_events",
        "lotus_idea_outbox_delivery_oldest_ready_age_seconds",
        "lotus_idea_outbox_delivery_configuration_ready",
        "lotus_idea_outbox_delivery_collection_success"
      ],
      "required_operations": [
        "outbox_delivery_readiness_read",
        "outbox_delivery_run_once"
      ],
      "required_labels": [
        "operation",
        "outcome",
        "supportability_status",
        "source_authority",
        "durable_storage_backed",
        "supported_feature_promoted"
      ],
      "required_endpoints": [
        "GET /api/v1/outbox-delivery/readiness",
        "POST /api/v1/outbox-delivery/run-once"
      ],
      "certification_status": "certified"
    },
    {
      "control_id": "downstream-realization-readiness-and-submission-posture",
      "operator_question": "Can operators distinguish downstream readiness blockers from local submission posture without claiming downstream execution outcomes?",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "downstream_realization_readiness_read",
        "downstream_realization_submission"
      ],
      "required_labels": [
        "operation",
        "outcome",
        "supportability_status",
        "source_authority",
        "durable_storage_backed",
        "supported_feature_promoted"
      ],
      "required_endpoints": [
        "GET /api/v1/downstream-realization/readiness",
        "POST /api/v1/conversion-intents/{conversionIntentId}/downstream-submissions",
        "POST /api/v1/report-evidence-packs/{reportEvidencePackId}/downstream-submissions"
      ],
      "certification_status": "certified"
    },
    {
      "control_id": "runtime-trust-and-implementation-proof-readiness-posture",
      "operator_question": "Can operators see runtime trust telemetry and aggregate implementation-proof readiness regressions before support promotion is considered?",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "mesh_readiness_read",
        "mesh_trust_telemetry_preview_read",
        "mesh_trust_telemetry_snapshot_read",
        "implementation_proof_readiness_read"
      ],
      "required_labels": [
        "operation",
        "outcome",
        "supportability_status",
        "source_authority",
        "durable_storage_backed",
        "supported_feature_promoted"
      ],
      "required_endpoints": [
        "GET /api/v1/data-mesh/readiness",
        "GET /api/v1/data-mesh/trust-telemetry/runtime-preview",
        "GET /api/v1/data-mesh/trust-telemetry/runtime-snapshot",
        "GET /api/v1/implementation-proof/readiness"
      ],
      "certification_status": "certified"
    }
  ],
  "operator_alert_candidates": [
    {
      "alert_id": "source-ingestion-readiness-blocked",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "source_ingestion_readiness_read",
        "source_ingestion_run_once"
      ],
      "required_outcomes": [
        "blocked",
        "invalid_state"
      ],
      "operator_response": "Use the source-ingestion readiness endpoint and configured manifest proof to separate missing configuration, unavailable Core query/control-plane URLs, and unproven scheduled-worker posture.",
      "certification_status": "certified"
    },
    {
      "alert_id": "outbox-delivery-readiness-blocked",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "outbox_delivery_readiness_read",
        "outbox_delivery_run_once"
      ],
      "required_outcomes": [
        "blocked",
        "invalid_state"
      ],
      "operator_response": "Inspect outbox readiness and run-once posture before retrying; preserve idempotent operator run identity and do not inspect raw downstream payloads.",
      "certification_status": "certified"
    },
    {
      "alert_id": "downstream-realization-readiness-blocked",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "downstream_realization_readiness_read",
        "downstream_realization_submission"
      ],
      "required_outcomes": [
        "blocked",
        "invalid_state",
        "permission_denied"
      ],
      "operator_response": "Use downstream realization readiness and local submission posture only; downstream execution, suitability, mandate, report rendering, and archive outcomes remain source-owned.",
      "certification_status": "certified"
    },
    {
      "alert_id": "implementation-proof-readiness-blocked",
      "implemented_metric_family": "lotus_idea_operation_events_total",
      "required_operations": [
        "mesh_readiness_read",
        "mesh_trust_telemetry_preview_read",
        "mesh_trust_telemetry_snapshot_read",
        "implementation_proof_readiness_read"
      ],
      "required_outcomes": [
        "blocked"
      ],
      "operator_response": "Use implementation-proof readiness to identify remaining blockers and preserve not-certified/support-promotion boundaries until all source, runtime, Gateway, Workbench, and CI evidence exists.",
      "certification_status": "certified"
    }
  ],
  "non_proof_boundaries": [
    "This contract is not live source-ingestion certification.",
    "This contract is not external broker runtime certification.",
    "This contract is not downstream execution outcome authority.",
    "This contract is not data-mesh certification.",
    "This contract is not Gateway or Workbench proof.",
    "This contract is not supported-feature promotion."
  ]
